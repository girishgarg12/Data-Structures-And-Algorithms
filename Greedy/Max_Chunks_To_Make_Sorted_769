class Solution {
    public int maxChunksToSorted(int[] arr) {
        int res=0;
        int min=arr[0];
        for(int i=0;i<arr.length;i++){
            if(arr[i]>min)  min=arr[i];
            if(min==i){
            res++;
            if(i<arr.length-1) min=arr[i+1];
            else break;
            } 
        }
        return res;
    }
}